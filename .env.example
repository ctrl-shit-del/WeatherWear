# SORS Environment Configuration
# Copy this file to .env and fill in your values

# OpenWeatherMap API Key (optional - app works in demo mode without it)
# Get a free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Groq API Key (console.groq.com) - Faster Fallout / High Quota
GROQ_API_KEY=your_groq_key_here

# Flask secret key (change this in production!)
SECRET_KEY=sors_super_secret_2026_change_me

# Server settings
PORT=5000
DEBUG=true
